{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/log-scan",
      "destination": "/api/serverless/log-scan.js"
    },
    {
      "source": "/api/submit-flag",
      "destination": "/api/serverless/submit-flag.js"
    },
    {
      "source": "/api/get-stats",
      "destination": "/api/serverless/get-stats.js"
    },
    {
      "source": "/api/system",
      "destination": "/api/serverless/debug-system.js"
    },
    {
      "source": "/api/v4/nova-server-status-7f2a",
      "destination": "/api/serverless/debug-system.js"
    },
    {
      "source": "/api/system/debug",
      "destination": "/api-static/debug/index.html"
    }
  ],
  "headers": [
    {
      "source": "/backup/(.*)",
      "headers": [
        {
          "key": "X-Internal-API-Location",
          "value": "/api/v4/nova-server-status-7f2a"
        }
      ]
    }
  ]
}